{
  "name": "kho-ai-backend",
  "version": "1.0.0",
  "description": "KHO AI - Warehouse Management System Backend",
  "main": "src/index.js",
  "scripts": {
    "db:migrate": "npx prisma migrate dev --name init",
    "db:push": "npx prisma db push",
    "db:seed": "node src/seed.js",
    "db:studio": "npx prisma studio",
    "db:setup": "npm run db:push && npm run db:seed",
    "start": "node src/index.js",
    "dev": "npx nodemon src/index.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "prisma": "^5.22.0"
  },
  "prisma": {
    "seed": "node src/seed.js"
  }
}